`timescale 1ns/1ps

module motor_control_tb;

/////////////////////////////////////////////////
// Signals
/////////////////////////////////////////////////

reg clk;
reg rst;

reg start;
reg emergency_stop;
reg overcurrent;

reg [15:0] sw;

wire fault_flag;

wire pwm_a_high, pwm_a_low;
wire pwm_b_high, pwm_b_low;
wire pwm_c_high, pwm_c_low;

/////////////////////////////////////////////////
// DUT
/////////////////////////////////////////////////

motor_control_top dut(
    .clk(clk),
    .rst(rst),

    .start(start),
    .emergency_stop(emergency_stop),
    .overcurrent(overcurrent),

    .sw(sw),

    .fault_flag(fault_flag),

    .pwm_a_high(pwm_a_high),
    .pwm_a_low(pwm_a_low),
    .pwm_b_high(pwm_b_high),
    .pwm_b_low(pwm_b_low),
    .pwm_c_high(pwm_c_high),
    .pwm_c_low(pwm_c_low)
);

/////////////////////////////////////////////////
// Clock
/////////////////////////////////////////////////

initial begin
    clk = 0;
    forever #5 clk = ~clk;
end

/////////////////////////////////////////////////
// Dump
/////////////////////////////////////////////////

initial begin
    $dumpfile("motor_control.vcd");
    $dumpvars(0, motor_control_tb);
end

/////////////////////////////////////////////////
// Monitor
/////////////////////////////////////////////////

initial begin
    $monitor("T=%0t | START=%b | FAULT=%b | PWM_A=%b",
        $time, start, fault_flag, pwm_a_high);
end

/////////////////////////////////////////////////
// TEST SEQUENCE
/////////////////////////////////////////////////

initial begin

// Initial state
rst = 1;
start = 1;             // inactive (IMPORTANT)
emergency_stop = 1;
overcurrent = 1;
sw = 0;

#20;
rst = 0;

/////////////////////////////////////////////////
// LOAD CONFIGURATION
/////////////////////////////////////////////////

sw[15] = 1;       // write_enable

sw[7:0] = 8'd100; // duty

#10;
sw[15] = 0;

/////////////////////////////////////////////////
// START MOTOR
/////////////////////////////////////////////////

start = 0;    // ACTIVE (IMPORTANT)
#300;

/////////////////////////////////////////////////
// CHANGE DUTY
/////////////////////////////////////////////////

sw[15] = 1;
sw[7:0] = 8'd200;
#10;
sw[15] = 0;

#300;

/////////////////////////////////////////////////
// FAULT: OVERCURRENT
/////////////////////////////////////////////////

overcurrent = 0;   // ACTIVE fault
#100;

overcurrent = 1;   // release fault

/////////////////////////////////////////////////
// CLEAR FAULT USING RESET
/////////////////////////////////////////////////

rst = 1;
#20;
rst = 0;

#200;

/////////////////////////////////////////////////
// RESTART MOTOR
/////////////////////////////////////////////////

start = 0;
#50;
start = 1;

#300;

/////////////////////////////////////////////////
// EMERGENCY STOP
/////////////////////////////////////////////////

emergency_stop = 0;
#100;

emergency_stop = 1;

/////////////////////////////////////////////////
// CLEAR AGAIN
/////////////////////////////////////////////////

rst = 1;
#20;
rst = 0;

#200;

$finish;

end

endmodule
