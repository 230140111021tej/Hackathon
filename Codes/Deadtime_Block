module deadtime_block #(
    parameter WIDTH = 12
)(
    input  wire clk,
    input  wire rst,

    input  wire pwm_in,

    input  wire [WIDTH-1:0] deadtime,

    output reg pwm_high,
    output reg pwm_low
);

reg [WIDTH-1:0] dead_counter;

always @(posedge clk or posedge rst) begin
    if (rst) begin
        pwm_high <= 0;
        pwm_low  <= 0;
        dead_counter <= 0;
    end
    else begin

        if (pwm_in == 1'b1) begin
            pwm_high <= 1;
            pwm_low  <= 0;
            dead_counter <= deadtime;
        end
        else begin
            if (dead_counter > 0) begin
                dead_counter <= dead_counter - 1;
                pwm_high <= 0;
                pwm_low  <= 0;
            end
            else begin
                pwm_high <= 0;
                pwm_low  <= 1;
            end
        end

    end
end

endmodule
