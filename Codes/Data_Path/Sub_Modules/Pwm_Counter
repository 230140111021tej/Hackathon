module pwm_counter #(
    parameter WIDTH = 12
)(
    input  wire clk,
    input  wire rst,
    input  wire enable,

    input  wire [WIDTH-1:0] max_count,

    output reg  [WIDTH-1:0] count
);

always @(posedge clk or posedge rst) begin
    if (rst)
        count <= 0;

    else if (enable) begin

        if (max_count == 0)
            count <= 0;

        else if (count >= max_count)
            count <= 0;

        else
            count <= count + 1;

    end
end

endmodule
